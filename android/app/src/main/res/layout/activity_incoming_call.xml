<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#B4AEA2"
    android:paddingLeft="24dp"
    android:paddingTop="40dp"
    android:paddingRight="24dp"
    android:paddingBottom="40dp">

    <LinearLayout
        android:id="@+id/layoutTop"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_marginTop="70dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvAvatarInitial"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:background="@drawable/circle_avatar"
            android:gravity="center"
            android:text="?"
            android:textColor="#FFFFFF"
            android:textSize="54sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:gravity="center"
            android:maxLines="2"
            android:shadowColor="#55000000"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:text="Unknown Caller"
            android:textColor="#FFFFFF"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvCallType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="Audio call from Messenger"
            android:textColor="#F3F3F3"
            android:textSize="18sp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="36dp"
        android:gravity="center"
        android:orientation="horizontal"
        android:weightSum="2">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnDecline"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/circle_red"
                android:contentDescription="Decline"
                android:padding="22dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_close_clear_cancel"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvDecline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Decline"
                android:textColor="#F0F0F0"
                android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:orientation="vertical">

            <ImageButton
                android:id="@+id/btnAccept"
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/circle_green"
                android:contentDescription="Accept"
                android:padding="22dp"
                android:scaleType="centerInside"
                android:src="@android:drawable/ic_menu_call"
                android:tint="#FFFFFF" />

            <TextView
                android:id="@+id/tvAccept"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Answer"
                android:textColor="#F0F0F0"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>
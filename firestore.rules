rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCallParticipant(callId) {
      let call = get(/databases/$(database)/documents/calls/$(callId)).data;
      return isAuthenticated() && (
        call.callerId == request.auth.uid ||
        call.calleeId == request.auth.uid ||
        request.auth.uid in call.get('participants', [])
      );
    }

    function isValidChatMessageCommon(data) {
      return data.senderId is string && data.senderId.size() > 0 &&
        data.receiverId is string && data.receiverId.size() > 0 &&
        data.type is string && data.type.size() > 0 &&
        data.text is string &&
        data.isDeleted is bool &&
        data.isRead is bool &&
        data.editCount is int &&
        data.timestamp is timestamp;
    }

    function canonicalChatId(userId1, userId2) {
      return userId1 < userId2
        ? userId1 + '_' + userId2
        : userId2 + '_' + userId1;
    }

    function isValidChatIdForParticipants(chatId, senderId, receiverId) {
      return chatId == canonicalChatId(senderId, receiverId);
    }

    function chatIdContainsUser(chatId, userId) {
      return userId in chatId.split('_');
    }

    function isValidChatMessageCreate(data) {
      return data.senderId == request.auth.uid &&
        // The app uses server timestamps; allow a little extra time for server-assigned values.
        data.timestamp is timestamp &&
        data.timestamp >= request.time - duration.value(10, 'm') &&
        data.timestamp <= request.time + duration.value(1, 'm') &&
        isValidChatMessageCommon(data);
    }

    function isValidChatMessageUpdate(data) {
      // Allow either party (sender or receiver) to update (read receipts, edits),
      // but keep core identity fields immutable.
      return (request.auth.uid == resource.data.senderId ||
              request.auth.uid == resource.data.receiverId) &&
        data.senderId == resource.data.senderId &&
        data.receiverId == resource.data.receiverId &&
        data.timestamp == resource.data.timestamp &&
        isValidChatMessageCommon(data);
    }

    match /users/{userId} {
      // The current app reads other user docs for names, email-based discovery,
      // and relationship state. Keep writes restricted.
      allow get, list: if isAuthenticated();
      allow create, update: if isOwner(userId);

      match /chat_settings/{otherUserId} {
        allow read: if isOwner(userId) || request.auth.uid == otherUserId;
        allow write: if isOwner(userId);
      }

      match /contacts/{contactUserId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId) || request.auth.uid == contactUserId;
        allow update: if isOwner(userId);
      }

      match /device_contacts/{contactId} {
        allow read, write: if isOwner(userId);
      }

      match /friend_requests/{requesterId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated() && request.auth.uid == requesterId;
        allow delete: if isOwner(userId) || request.auth.uid == requesterId;
        allow update: if isOwner(userId);
      }

      match /sent_friend_requests/{targetUserId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId) || request.auth.uid == targetUserId;
        allow update: if isOwner(userId);
      }

      match /quarantine/{entryId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /chats/{chatId} {
      allow read: if isAuthenticated() && (
        (resource != null &&
          request.auth.uid in resource.data.get('participants', [])) ||
        chatIdContainsUser(chatId, request.auth.uid)
      );
      allow write: if isAuthenticated() && (
        (resource != null && request.auth.uid in resource.data.get('participants', [])) ||
        (request.resource.data.participants is list &&
          request.auth.uid in request.resource.data.participants) ||
        chatIdContainsUser(chatId, request.auth.uid)
      );

      match /messages/{messageId} {
        allow read: if isAuthenticated() && (
          resource.data.senderId == request.auth.uid ||
          resource.data.receiverId == request.auth.uid ||
          chatIdContainsUser(chatId, request.auth.uid)
        );
        allow create: if isAuthenticated() &&
                      request.resource.data.senderId == request.auth.uid &&
                      isValidChatIdForParticipants(chatId, request.resource.data.senderId, request.resource.data.receiverId) &&
                      isValidChatMessageCreate(request.resource.data);
        allow update: if isAuthenticated() &&
                      (request.auth.uid == resource.data.senderId ||
                       request.auth.uid == resource.data.receiverId) &&
                      // Apply the same validation to the post-update document.
                      isValidChatMessageUpdate(request.resource.data);
        allow delete: if false;
      }
    }

    // Collection-group message listeners rely on document fields directly.
    // Keep this read-only and narrow it to sender/receiver ownership.
    match /{path=**}/messages/{messageId} {
      allow read: if isAuthenticated() && (
        request.auth.uid in get(/databases/$(database)/documents/$(path)).data.get('participants', []) ||
        resource.data.senderId == request.auth.uid ||
        resource.data.receiverId == request.auth.uid
      );
    }

    match /calls/{callId} {
      allow read: if isCallParticipant(callId);
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      allow update: if isCallParticipant(callId);
      allow delete: if false;

      match /offerCandidates/{candidateId} {
        allow read, write: if isCallParticipant(callId);
      }

      match /answerCandidates/{candidateId} {
        allow read, write: if isCallParticipant(callId);
      }
    }
  }
}

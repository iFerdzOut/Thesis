rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Collection: users
    // ===============================================================
    match /users/{userId} {
      // A user can read and update their own document.
      // PII (email, etc.) is in this doc, so only the owner can read.
      allow read, update: if isOwner(userId);

      // Allow other authenticated users to get a user's public key for E2EE.
      // This is safe because we are only exposing non-sensitive fields.
      allow get: if isAuthenticated() &&
        !('email' in resource.data) &&
        !('e2eeRecoverySalt' in resource.data);

      // Rules for Signal Protocol device bundles
      match /devices/{deviceId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      // Rules for legacy E2EE sessions
      match /e2ee_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }

      // Rules for the incremental message backup chunks
      match /message_backups/{backupId} {
        // Users can read and delete their own backup chunks.
        allow read, delete: if isOwner(userId);

        // Users can create new backup chunks with valid data.
        allow create: if isOwner(userId) && isValidMessageBackup(request.resource.data);

        // Updates to backup chunks are not allowed.
        allow update: if false;
      }
    }

    // ===============================================================
    // Collection: chats
    // ===============================================================
    match /chats/{chatId} {
      // Users can only read/write to chats they are a part of.
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;

      // Messages subcollection
      match /messages/{messageId} {
        // Users can read messages in a chat they are part of.
        allow read: if isAuthenticated() && get(/databases/$(database)/documents/chats/$(chatId)).data.participants.hasAny([request.auth.uid]);

        // Users can only create messages where they are the sender.
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;

        // Users can only update their own messages (e.g., to delete).
        allow update: if isAuthenticated() && resource.data.senderId == request.auth.uid;

        // Users cannot delete message documents directly. They should be updated with a "deleted" status.
        allow delete: if false;
      }
    }

    // ===============================================================
    // Collection: calls
    // ===============================================================
    match /calls/{callId} {
      // Only participants of the call can access the call document.
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
    }

    // ===============================================================
    // Domain-Specific Validators
    // ===============================================================
    function isValidMessageBackup(data) {
      let allowedFields = ['version', 'salt', 'nonce', 'mac', 'cipherText', 'savedAt'];
      return data.keys().hasAll(allowedFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.version == 2 &&
             data.salt is string && data.salt.size() > 10 && data.salt.size() < 40 &&
             data.nonce is string && data.nonce.size() > 10 && data.nonce.size() < 40 &&
             data.mac is string && data.mac.size() > 10 && data.mac.size() < 60 &&
             data.cipherText is string && data.cipherText.size() > 0 && data.cipherText.size() < 1048000 &&
             request.resource.data.savedAt == request.time;
    }
  }
}
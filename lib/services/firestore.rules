rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isCallParticipant() {
      return isAuthenticated() && (
        resource.data.callerId == request.auth.uid ||
        resource.data.calleeId == request.auth.uid ||
        request.auth.uid in resource.data.participants
      );
    }

    match /users/{userId} {
      // The current app reads other user docs for names, email-based discovery,
      // E2EE public keys, and relationship state. Keep writes restricted.
      allow get, list: if isAuthenticated();
      allow create, update: if isOwner(userId);

      match /devices/{deviceId} {
        allow read: if isAuthenticated();
        allow write: if isOwner(userId);
      }

      match /message_backups/{backupId} {
        allow read, delete: if isOwner(userId);
        allow create: if isOwner(userId) && isValidMessageBackup(request.resource.data);
        allow update: if false;
      }

      match /chat_settings/{otherUserId} {
        allow read: if isOwner(userId) || request.auth.uid == otherUserId;
        allow write: if isOwner(userId);
      }

      match /contacts/{contactUserId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId) || request.auth.uid == contactUserId;
        allow update: if isOwner(userId);
      }

      match /friend_requests/{requesterId} {
        allow read: if isOwner(userId);
        allow create: if isAuthenticated() && request.auth.uid == requesterId;
        allow delete: if isOwner(userId) || request.auth.uid == requesterId;
        allow update: if isOwner(userId);
      }

      match /sent_friend_requests/{targetUserId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow delete: if isOwner(userId) || request.auth.uid == targetUserId;
        allow update: if isOwner(userId);
      }

      match /quarantine/{entryId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /chats/{chatId} {
      allow read, write: if isAuthenticated() && request.auth.uid in chatId.split('_');

      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in chatId.split('_');
        allow create: if isAuthenticated() && 
                      request.auth.uid in chatId.split('_') && 
                      request.resource.data.senderId == request.auth.uid;
        allow update: if isAuthenticated() && request.auth.uid in chatId.split('_');
        allow delete: if false;
      }
    }

    match /{path=**}/messages/{messageId} {
      allow read: if isAuthenticated() &&
        resource != null &&
        (
          resource.data.receiverId == request.auth.uid ||
          resource.data.senderId == request.auth.uid
        );
    }

    match /calls/{callId} {
      allow read: if isCallParticipant();
      allow create: if isAuthenticated() && request.resource.data.callerId == request.auth.uid;
      allow update: if isCallParticipant();
      allow delete: if false;

      match /offerCandidates/{candidateId} {
        allow read, write: if isCallParticipant();
      }

      match /answerCandidates/{candidateId} {
        allow read, write: if isCallParticipant();
      }
    }

    function isValidMessageBackup(data) {
      let allowedFields = ['version', 'salt', 'nonce', 'mac', 'cipherText', 'savedAt'];
      return data.keys().hasAll(allowedFields) &&
             data.keys().hasOnly(allowedFields) &&
             data.version == 2 &&
             data.salt is string && data.salt.size() > 10 && data.salt.size() < 40 &&
             data.nonce is string && data.nonce.size() > 10 && data.nonce.size() < 40 &&
             data.mac is string && data.mac.size() > 10 && data.mac.size() < 60 &&
             data.cipherText is string && data.cipherText.size() > 0 && data.cipherText.size() < 1048000 &&
             request.resource.data.savedAt == request.time;
    }
  }
}